{
    "manifest_version": 3,
    "name": "Data Grabber",
    "version": "1.0",
    "permissions": ["activeTab", "scripting", "tabs"],
    "background": {
      "service_worker": "background.js"
    },
    "host_permissions": ["https://canvas.kth.se/*", "http://localhost:5000/*"],
    "action": {
      "default_popup": "popup.html"
    }
}